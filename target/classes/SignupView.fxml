<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root" xmlns:fx="http://javafx.com/fxml" fx:controller="com.sportsintel.SignupController">

    <children>
        <VBox alignment="CENTER" maxWidth="420" spacing="24" styleClass="login-card">
            <children>

                <ImageView fx:id="signupLogo" fitHeight="120" fitWidth="120" preserveRatio="true" />

                <Label styleClass="login-title" text="Signup" />

                <VBox maxWidth="350" spacing="8">
                    <children>
                        <Label styleClass="login-label" text="Email" />
                        <TextField fx:id="email_txt" prefHeight="48.0" prefWidth="350.0" promptText="" styleClass="login-field" />
                    </children>
                </VBox>

                <VBox maxWidth="350" spacing="8">
                    <children>
                        <Label styleClass="login-label" text="Password" />
                        <PasswordField fx:id="pass_txt" prefHeight="48.0" prefWidth="350.0" promptText="" styleClass="login-field" />
                    </children>
                </VBox>
            <VBox maxWidth="350" spacing="8">
               <children>
                  <Label styleClass="login-label" text="Phone Number" />
                  <TextField fx:id="phone_txt" prefHeight="48.0" prefWidth="350.0" promptText="" styleClass="login-field" />
               </children>
            </VBox>
            <VBox maxWidth="350" spacing="8">
               <children>
                  <Label styleClass="login-label" text="Display Name" />
                  <TextField fx:id="disName_txt" prefHeight="48.0" prefWidth="350.0" promptText="" styleClass="login-field" />
               </children>
            </VBox>

                <Button prefHeight="52.0" prefWidth="350" styleClass="login-enter-btn" text="Enter" onAction="#userSignup"/>

                <Hyperlink onAction="#handleBackToHome" styleClass="login-link" text="Back to Home" />

            </children>

            <padding>
                <Insets bottom="35" left="30" right="30" top="35" />
            </padding>
        </VBox>
    </children>
</StackPane>
