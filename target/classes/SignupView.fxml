<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="signup-root" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="com.sportsintel.SignUpController">

    <children>
        <VBox alignment="CENTER" maxWidth="450" spacing="20" styleClass="signup-card">
            <children>

                <ImageView fx:id="signUpLogo" fitHeight="120" fitWidth="120" preserveRatio="true" />

                <Label styleClass="signup-title" text="Sign Up" />

                <VBox maxWidth="360" spacing="8">
                    <children>
                        <Label fx:id="input_error_lbl" styleClass="signup-label" text="User input invalid. Please make sure all fields are correct" textFill="RED" />
                    </children>
                </VBox>

                <VBox maxWidth="360" spacing="8">
                    <children>
                        <Label fx:id="first_name_lbl" styleClass="signup-label" text="First Name" />
                        <TextField fx:id="first_name_txt" prefHeight="46" promptText="John" styleClass="signup-field" />
                    </children>
                </VBox>

                <VBox maxWidth="360" spacing="8">
                    <children>
                        <Label fx:id="last_name_lbl" styleClass="signup-label" text="Last Name" />
                        <TextField fx:id="last_name_txt" prefHeight="46" promptText="Doe" styleClass="signup-field" />
                    </children>
                </VBox>
                <VBox maxWidth="360" spacing="8">
                    <children>
                        <Label fx:id="phone_lbl" styleClass="signup-label" text="Phone Number" />
                        <TextField fx:id="phone_txt" prefHeight="46" promptText="+19999999999" styleClass="signup-field" />
                    </children>
                </VBox>

                <VBox maxWidth="360" spacing="8">
                    <children>
                        <Label fx:id="email_lbl" styleClass="signup-label" text="Email" />
                        <TextField fx:id="email_txt" prefHeight="46" promptText="johndoe@gmail,com" styleClass="signup-field" />
                    </children>
                </VBox>

                <VBox maxWidth="360" spacing="8">
                    <children>
                        <Label fx:id="user_lbl" styleClass="signup-label" text="Username" />
                        <TextField fx:id="user_txt" prefHeight="46" promptText="JohnDoe" styleClass="signup-field" />
                    </children>
                </VBox>

                <VBox maxWidth="360" spacing="8">
                    <children>
                        <Label fx:id="pass_lbl" styleClass="signup-label" text="Password" />
                        <PasswordField fx:id="pass_txt" prefHeight="46" styleClass="signup-field" />
                    </children>
                </VBox>

                <VBox maxWidth="360" spacing="8">
                    <children>
                        <Label fx:id="confirm_pass_lbl" styleClass="signup-label" text="Confirm Password" />
                        <PasswordField fx:id="confirm_pass_txt" prefHeight="46" styleClass="signup-field" />
                    </children>
                </VBox>

                <Button onAction="#handleSignUpSubmit" prefHeight="50" prefWidth="360" styleClass="signup-enter-btn" text="Enter" />

                <Hyperlink onAction="#handleBackToHome" styleClass="signup-link" text="Back to Home" />

            </children>

            <padding>
                <Insets bottom="32" left="30" right="30" top="32" />
            </padding>
        </VBox>
    </children>
</StackPane>
