<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sportsintel.HomeController"
            styleClass="home-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="top-bar">
            <children>
                <ImageView fx:id="navLogo"
                           fitWidth="100"
                           fitHeight="100"
                           preserveRatio="true" />

                <Label text="SportsIntel Analytics" styleClass="top-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Home" styleClass="home-btn" />
                <Button text="Compare" styleClass="compare-btn" onAction="#handleCompareClick" />
                <Button text="Help" styleClass="help-btn" onAction="#handleHelpClick" />

                <HBox fx:id="authButtons" spacing="10" alignment="CENTER_RIGHT">
                    <children>
                        <Button text="Login" styleClass="login-btn" onAction="#handleLoginClick" />
                        <Button text="Sign Up" styleClass="signup-btn" onAction="#handleSignUpClick" />
                    </children>
                </HBox>

                <VBox fx:id="profileBox" visible="false" managed="false">
                    <children>
                        <StackPane fx:id="profileButton"
                                   onMouseClicked="#toggleProfileMenu"
                                   styleClass="profile-circle">
                            <Label text="👤" styleClass="profile-icon-text"/>

                            <ImageView fx:id="profileImage"
                                       fitWidth="32"
                                       fitHeight="32"
                                       preserveRatio="true"/>
                        </StackPane>
                    </children>
                </VBox>
            </children>

            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>
        </HBox>
    </top>
    <left>
        <VBox alignment="TOP_CENTER">
            <children>
                <Region prefHeight="100" />
                <VBox spacing="14" styleClass="sidebar">
                    <children>

                        <Label text="Filters" styleClass="sidebar-title" />

                        <VBox spacing="6">
                            <Label text="Season Range" styleClass="field-label" />

                            <HBox spacing="6">
                                <TextField fx:id="seasonStartField" promptText="1949" prefWidth="70"/>
                                <Label text="to" />
                                <TextField fx:id="seasonEndField" promptText="2026" prefWidth="70"/>
                            </HBox>

                        </VBox>

                        <VBox spacing="6">
                            <Label text="Season Type" styleClass="field-label" />
                            <ComboBox fx:id="seasonTypeCombo" promptText="Both" />
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Location" styleClass="field-label" />
                            <ComboBox fx:id="locationCombo" promptText="Both" />
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Last N Games vs Opponent" styleClass="field-label" />
                            <TextField fx:id="lastNGamesField" promptText="10" />
                        </VBox>

                        <Button text="Apply Filters" styleClass="filters-btn" />
                        <Button text="Reset" styleClass="reset-btn" />

                    </children>

                    <padding>
                        <Insets top="20" right="14" bottom="20" left="14"/>
                    </padding>
                </VBox>

            </children>
        </VBox>
    </left>
    <center>
        <StackPane styleClass="center-area">
            <children>
                <VBox spacing="22" maxWidth="760" styleClass="search-card" alignment="CENTER">
                    <children>
                        <ImageView fx:id="mainLogo"
                                   fitWidth="300"
                                   fitHeight="300"
                                   preserveRatio="true" />
                        <Label text="Analyze Player Performance vs&#10;Team"
                               styleClass="main-title"
                               wrapText="true" />
                        <HBox spacing="20" alignment="CENTER">
                            <children>
                                <VBox spacing="6" prefWidth="260">
                                    <children>
                                        <Label text="Player Name" styleClass="field-label" />
                                        <TextField fx:id="playerNameField"
                                                   promptText="Enter player name"
                                                   prefWidth="260" />
                                    </children>
                                </VBox>
                                <VBox spacing="6" prefWidth="260">
                                    <children>
                                        <Label text="Sport" styleClass="field-label" />
                                        <ComboBox fx:id="sportCombo"
                                                  promptText="Select sport"
                                                  prefWidth="260" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <HBox spacing="20" alignment="CENTER">
                            <children>
                                <VBox spacing="6" prefWidth="260">
                                    <children>
                                        <Label text="Opponent" styleClass="field-label" />
                                        <ComboBox fx:id="opponentCombo"
                                                  promptText="Select opponent"
                                                  prefWidth="260" />
                                    </children>
                                </VBox>
                                <VBox spacing="6" prefWidth="260">
                                    <children>
                                        <Label text="Statistic" styleClass="field-label" />
                                        <ComboBox fx:id="statisticCombo"
                                                  promptText="Select statistic"
                                                  prefWidth="260" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <Button text="Search"
                                styleClass="search-btn"
                                prefWidth="540"
                                prefHeight="44"
                                onAction="#handleSearchClick"/>
                    </children>
                    <padding>
                        <Insets top="30" right="35" bottom="30" left="35"/>
                    </padding>
                </VBox>

                <VBox fx:id="profileMenu"
                      visible="false"
                      managed="false"
                      maxWidth="300"
                      prefWidth="300"
                      spacing="12"
                      styleClass="profile-menu"
                      StackPane.alignment="TOP_RIGHT"
                      translateX="-10"
                      translateY="20">

                    <children>
                        <VBox spacing="4">
                            <children>
                                <Label fx:id="profileNameLabel"
                                       text="Dan Gron"
                                       styleClass="profile-name" />
                                <Label fx:id="profileUsernameLabel"
                                       text="@ForeignStage"
                                       styleClass="profile-username" />
                            </children>
                        </VBox>

                        <Separator />

                        <Label text="No search history yet. Start searching to see your history here!"
                               wrapText="true"
                               styleClass="profile-history" />

                        <Separator />

                        <Button text="Logout"
                                styleClass="logout-btn"
                                onAction="#handleLogout" />
                    </children>

                    <padding>
                        <Insets top="14" right="14" bottom="14" left="14"/>
                    </padding>
                </VBox>

            </children>
        </StackPane>
    </center>
</BorderPane>