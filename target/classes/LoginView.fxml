<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="com.sportsintel.LoginController">

    <children>
        <VBox alignment="CENTER" maxWidth="420" spacing="24" styleClass="login-card">
            <children>

                <ImageView fx:id="loginLogo" fitHeight="120" fitWidth="120" preserveRatio="true" />

                <Label styleClass="login-title" text="Login" />

                <VBox maxWidth="350" spacing="8">
                    <children>
                  <HBox prefHeight="22.0" prefWidth="350.0">
                     <children>
                              <Label styleClass="login-label" text="Email" />
                        <Label fx:id="user_error" prefHeight="18.0" prefWidth="118.0"  text="Incorrect Email" textFill="RED" visible="false">
                           <HBox.margin>
                              <Insets left="10.0" />
                           </HBox.margin>
                        </Label>
                     </children>
                  </HBox>
                        <TextField fx:id="user_txt" prefHeight="48" promptText="" styleClass="login-field" />
                    </children>
                </VBox>

                <VBox maxWidth="350" spacing="8">
                    <children>
                        <Label styleClass="login-label" text="Password" />
                        <PasswordField fx:id="pass_txt" prefHeight="48" promptText="" styleClass="login-field" />
                    </children>
                </VBox>

                <Button prefHeight="52" prefWidth="350" styleClass="login-enter-btn" text="Enter" onAction="#verifyUser" />

                <Hyperlink onAction="#handleBackToHome" styleClass="login-link" text="Back to Home" />

            </children>

            <padding>
                <Insets bottom="35" left="30" right="30" top="35" />
            </padding>
        </VBox>
    </children>
</StackPane>
