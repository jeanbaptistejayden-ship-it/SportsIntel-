<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import java.lang.String?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sportsintel.ResultsController"
            styleClass="home-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="top-bar">
            <children>
                <ImageView fx:id="navLogo"
                           fitWidth="100"
                           fitHeight="100"
                           preserveRatio="true" />

                <Label text="SportsIntel Analytics" styleClass="top-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Home" styleClass="home-btn" onAction="#handleHomeClick" />
                <Button text="Compare" styleClass="compare-btn" onAction="#handleCompareClick" />
                <Button text="Help" styleClass="help-btn" onAction="#handleHelpClick" />
                <Button text="Login" styleClass="login-btn" onAction="#handleLoginClick" />
                <Button text="Sign Up" styleClass="signup-btn" onAction="#handleSignUpClick" />
            </children>

            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>
        </HBox>
    </top>

    <left>
        <VBox alignment="TOP_CENTER">
            <children>
                <Region prefHeight="100" />

                <VBox spacing="18" styleClass="sidebar">
                    <children>
                        <Label text="Applied Filters" styleClass="sidebar-title" />

                        <VBox spacing="6">
                            <Label text="Season Range" styleClass="field-label" />
                            <Label text="2018 - 2026" styleClass="filter-value" />
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Season Type" styleClass="field-label" />
                            <Label text="Both" styleClass="filter-value" />
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Location" styleClass="field-label" />
                            <Label text="Home" styleClass="filter-value" />
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Last N Games vs Opponent" styleClass="field-label" />
                            <Label text="10" styleClass="filter-value" />
                        </VBox>
                    </children>

                    <padding>
                        <Insets top="20" right="14" bottom="20" left="14"/>
                    </padding>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane styleClass="center-area">
            <children>
                <VBox spacing="22"
                      alignment="TOP_CENTER"
                      maxWidth="760"
                      styleClass="results-card">

                    <children>

                        <VBox spacing="8" alignment="CENTER">
                            <children>
                                <Label text="Player: LeBron James" styleClass="result-summary" />
                                <Label text="Opponent: New York Knicks" styleClass="result-summary" />
                                <Label text="Statistic: Points Per Game" styleClass="result-summary" />
                            </children>
                        </VBox>

                        <StackPane alignment="CENTER">
                            <children>

                                <GridPane hgap="100" vgap="30" alignment="CENTER">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT"/>
                                        <ColumnConstraints hgrow="ALWAYS" halignment="LEFT"/>
                                    </columnConstraints>

                                    <children>
                                        <VBox GridPane.rowIndex="0" GridPane.columnIndex="0"
                                              spacing="10"
                                              alignment="CENTER"
                                              prefWidth="300"
                                              prefHeight="180">
                                            <styleClass>
                                                <String fx:value="stat-box"/>
                                                <String fx:value="avg-box"/>
                                            </styleClass>
                                            <children>
                                                <Label text="Average PPG vs Knicks" styleClass="stat-title" />
                                                <Label text="27.7" styleClass="avg-number" />
                                                <Label text="points" styleClass="stat-unit" />
                                            </children>
                                            <padding>
                                                <Insets top="20" right="20" bottom="20" left="20"/>
                                            </padding>
                                        </VBox>

                                        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1"
                                              spacing="10"
                                              alignment="CENTER"
                                              prefWidth="300"
                                              prefHeight="180">
                                            <styleClass>
                                                <String fx:value="stat-box"/>
                                                <String fx:value="games-box"/>
                                            </styleClass>
                                            <children>
                                                <Label text="Games Played" styleClass="stat-title" />
                                                <Label text="10" styleClass="games-number" />
                                                <Label text="games" styleClass="stat-unit" />
                                            </children>
                                            <padding>
                                                <Insets top="20" right="20" bottom="20" left="20"/>
                                            </padding>
                                        </VBox>

                                        <VBox GridPane.rowIndex="1" GridPane.columnIndex="0"
                                              spacing="10"
                                              alignment="CENTER"
                                              prefWidth="300"
                                              prefHeight="180">
                                            <styleClass>
                                                <String fx:value="stat-box"/>
                                                <String fx:value="high-box"/>
                                            </styleClass>
                                            <children>
                                                <Label text="Highest Game" styleClass="stat-title" />
                                                <Label text="33" styleClass="high-number" />
                                                <Label text="points" styleClass="stat-unit" />
                                            </children>
                                            <padding>
                                                <Insets top="20" right="20" bottom="20" left="20"/>
                                            </padding>
                                        </VBox>

                                        <VBox GridPane.rowIndex="1" GridPane.columnIndex="1"
                                              spacing="10"
                                              alignment="CENTER"
                                              prefWidth="300"
                                              prefHeight="180">
                                            <styleClass>
                                                <String fx:value="stat-box"/>
                                                <String fx:value="low-box"/>
                                            </styleClass>
                                            <children>
                                                <Label text="Lowest Game" styleClass="stat-title" />
                                                <Label text="21" styleClass="low-number" />
                                                <Label text="points" styleClass="stat-unit" />
                                            </children>
                                            <padding>
                                                <Insets top="20" right="20" bottom="20" left="20"/>
                                            </padding>
                                        </VBox>
                                    </children>
                                </GridPane>

                                <ImageView fx:id="centerLogo"
                                           fitWidth="350"
                                           fitHeight="350"
                                           preserveRatio="true" />
                            </children>
                        </StackPane>

                    </children>

                    <padding>
                        <Insets top="28" right="35" bottom="30" left="35"/>
                    </padding>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>