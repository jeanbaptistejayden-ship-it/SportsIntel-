<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sportsintel.HomeController"
            styleClass="home-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="top-bar">
            <children>
                <ImageView fx:id="navLogo"
                           fitWidth="100"
                           fitHeight="100"
                           preserveRatio="true" />

                <Label text="SportsIntel Analytics"
                       styleClass="top-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Home" styleClass="home-btn " />
                <Button text="Help" styleClass="help-button" />
                <Button text="Login" styleClass="login-btn" />
                <Button text="Sign Up" styleClass="signup-btn" />
            </children>

            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>
        </HBox>
    </top>
</BorderPane>