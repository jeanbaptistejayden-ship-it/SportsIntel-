<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sportsintel.CompareResultsController"
           styleClass="home-root">

    <children>

        <BorderPane>

            <top>
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="top-bar">
                    <children>
                        <ImageView fx:id="navLogo"
                                   fitWidth="100"
                                   fitHeight="100"
                                   preserveRatio="true" />
                        <Label text="SportsIntel Analytics" styleClass="top-title" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Home" styleClass="home-btn" onAction="#handleHomeClick" />
                        <Button text="Compare" styleClass="compare-btn" onAction="#handleCompareClick" />
                        <Button text="Help" styleClass="help-btn" onAction="#handleHelpClick" />
                        <HBox fx:id="authButtons" spacing="10" alignment="CENTER_RIGHT">
                            <children>
                                <Button text="Login" styleClass="login-btn" onAction="#handleLoginClick" />
                                <Button text="Sign Up" styleClass="signup-btn" onAction="#handleSignUpClick" />
                            </children>
                        </HBox>

                        <VBox fx:id="profileBox" visible="false" managed="false">
                            <children>
                                <StackPane fx:id="profileButton"
                                           onMouseClicked="#toggleProfileMenu"
                                           styleClass="profile-circle">
                                    <Label text="👤" styleClass="profile-icon-text"/>
                                    <children>
                                        <ImageView fx:id="profileImage"
                                                   fitWidth="32"
                                                   fitHeight="32"
                                                   preserveRatio="true" />
                                    </children>
                                </StackPane>
                            </children>
                        </VBox>
                    </children>

                    <padding>
                        <Insets top="16" right="20" bottom="16" left="20"/>
                    </padding>
                </HBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            pannable="true"
                            styleClass="compare-scroll">
                    <content>
                        <StackPane styleClass="center-area">
                            <children>
                                <VBox spacing="24"
                                      maxWidth="980"
                                      alignment="TOP_CENTER"
                                      styleClass="compare-results-wrapper">
                                    <children>

                                        <HBox spacing="60" alignment="CENTER" styleClass="compare-results-header">

                                            <VBox spacing="10" alignment="CENTER">
                                                <Label text="Player Comparison" styleClass="compare-results-title" />
                                                <Label fx:id="comparisonSubtitleLabel"
                                                       styleClass="compare-results-subtitle" />
                                                <Label text="Data: 2014-15 to Present (Career)"
                                                       styleClass="compare-results-note" />
                                            </VBox>

                                        </HBox>

                                        <HBox spacing="28" alignment="CENTER">
                                            <children>

                                                <StackPane prefWidth="460"
                                                           prefHeight="84"
                                                           styleClass="player-name-card,left-player-card">
                                                    <children>
                                                        <Label fx:id="playerOneNameLabel" styleClass="player-name-title" />
                                                    </children>
                                                </StackPane>

                                                <StackPane prefWidth="460"
                                                           prefHeight="84"
                                                           styleClass="player-name-card,right-player-card">
                                                    <children>
                                                        <Label fx:id="playerTwoNameLabel" styleClass="player-name-title" />
                                                    </children>
                                                </StackPane>

                                            </children>
                                        </HBox>
                                        <VBox spacing="18"
                                              maxWidth="980"
                                              alignment="CENTER"
                                              styleClass="compare-stats-card">
                                            <children>
                                                <Label text="Head-to-Head Statistics" styleClass="compare-section-title"/>

                                                <VBox spacing="10" maxWidth="920" alignment="CENTER">
                                                    <children>
                                                        <Label text="Points Per Game"
                                                               styleClass="stat-label"
                                                               alignment="CENTER"
                                                               maxWidth="Infinity"/>

                                                        <HBox spacing="20" alignment="CENTER">
                                                            <children>
                                                                <StackPane fx:id="pointsLeftBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-win">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="pointsLeftLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="pointsLeftArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>

                                                                <StackPane fx:id="pointsRightBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-lose">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="pointsRightLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="pointsRightArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>
                                                            </children>
                                                        </HBox>

                                                        <Label fx:id="pointsDiffLabel"
                                                               styleClass="stat-diff"
                                                               alignment="CENTER"
                                                               maxWidth="Infinity"/>
                                                        <Separator/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="10" maxWidth="920" alignment="CENTER">
                                                    <children>
                                                        <Label text="Assists Per Game"
                                                               styleClass="stat-label"
                                                               alignment="CENTER"
                                                               maxWidth="Infinity"/>

                                                        <HBox spacing="20" alignment="CENTER">
                                                            <children>
                                                                <StackPane fx:id="assistsLeftBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-lose">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="assistsLeftLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="assistsLeftArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>

                                                                <StackPane fx:id="assistsRightBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-win">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="assistsRightLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="assistsRightArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>
                                                            </children>
                                                        </HBox>

                                                        <Label fx:id="assistsDiffLabel" text="Difference: 0.1"
                                                               styleClass="stat-diff"
                                                               alignment="CENTER"
                                                               maxWidth="Infinity"/>
                                                        <Separator/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="10" maxWidth="920" alignment="CENTER">
                                                    <children>
                                                        <Label text="Rebounds Per Game" styleClass="stat-label"/>
                                                        <HBox spacing="20" alignment="CENTER">
                                                            <children>
                                                                <StackPane fx:id="reboundsLeftBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-win">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="reboundsLeftLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="reboundsLeftArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>

                                                                <StackPane fx:id="reboundsRightBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-lose">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="reboundsRightLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="reboundsRightArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>
                                                            </children>
                                                        </HBox>

                                                        <Label fx:id="reboundsDiffLabel"
                                                               styleClass="stat-diff"
                                                               alignment="CENTER"
                                                               maxWidth="Infinity"/>
                                                        <Separator/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="10" maxWidth="920" alignment="CENTER">
                                                    <children>
                                                        <Label text="Field Goal %" styleClass="stat-label"/>
                                                        <HBox spacing="20" alignment="CENTER">
                                                            <children>
                                                                <StackPane fx:id="fgPctLeftBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-win">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="fgPctLeftLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="fgPctLeftArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>

                                                                <StackPane fx:id="fgPctRightBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-lose">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="fgPctRightLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="fgPctRightArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>
                                                            </children>
                                                        </HBox>

                                                        <Label fx:id="fgPctDiffLabel"
                                                               styleClass="stat-diff"
                                                               alignment="CENTER"
                                                               maxWidth="Infinity"/>
                                                        <Separator/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="10" maxWidth="920" alignment="CENTER">
                                                    <children>
                                                        <Label text="Minutes Per Game" styleClass="stat-label"/>
                                                        <HBox spacing="20" alignment="CENTER">
                                                            <children>
                                                                <StackPane fx:id="minutesLeftBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-win">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="minutesLeftLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="minutesLeftArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>
                                                                <StackPane fx:id="minutesRightBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-lose">
                                                                    <children>
                                                                        <VBox alignment="CENTER">
                                                                            <Label fx:id="minutesRightLabel" styleClass="stat-number"/>
                                                                            <Label fx:id="minutesRightArrow" text="↗" styleClass="stat-arrow"/>
                                                                        </VBox>
                                                                    </children>
                                                                </StackPane>
                                                            </children>
                                                        </HBox>
                                                        <Label fx:id="minutesDiffLabel"
                                                               styleClass="stat-diff"
                                                               alignment="CENTER"
                                                               maxWidth="Infinity"/>
                                                        <Separator/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="10" maxWidth="920" alignment="CENTER">
                                                    <children>
                                                        <Label text="Games Played" styleClass="stat-label"/>
                                                        <HBox spacing="20" alignment="CENTER">
                                                            <children>
                                                                <StackPane fx:id="gamesLeftBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-lose">
                                                                    <children>
                                                                        <Label fx:id="gamesLeftLabel" styleClass="stat-number"/>
                                                                    </children>
                                                                </StackPane>

                                                                <StackPane fx:id="gamesRightBox" prefWidth="440" prefHeight="80"
                                                                           styleClass="stat-box,stat-lose">
                                                                    <children>
                                                                        <Label fx:id="gamesRightLabel" styleClass="stat-number"/>
                                                                    </children>
                                                                </StackPane>
                                                            </children>
                                                        </HBox>
                                                        <Separator/>
                                                    </children>
                                                </VBox>

                                            </children>
                                            <padding>
                                                <Insets top="20" right="20" bottom="20" left="20"/>
                                            </padding>
                                        </VBox>

                                        <VBox spacing="20"
                                              maxWidth="980"
                                              styleClass="analysis-card">
                                            <children>
                                                <Label text="Performance Analysis"
                                                       styleClass="analysis-title"/>

                                                <HBox spacing="40" alignment="CENTER">
                                                    <children>
                                                        <VBox spacing="10" prefWidth="440">
                                                            <children>
                                                                <Label fx:id="analysisPlayerOneLabel"
                                                                       styleClass="analysis-player-name"/>

                                                                <Label fx:id="analysisPlayerOneTextLabel"
                                                                       wrapText="true"
                                                                       styleClass="analysis-box-left"/>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="10" prefWidth="440">
                                                            <children>
                                                                <Label fx:id="analysisPlayerTwoLabel"
                                                                       styleClass="analysis-player-name"/>

                                                                <Label fx:id="analysisPlayerTwoTextLabel"
                                                                       wrapText="true"
                                                                       styleClass="analysis-box-right"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                            <padding>
                                                <Insets top="22" right="22" bottom="22" left="22"/>
                                            </padding>
                                        </VBox>
                                        <Button text="New Comparison"
                                                prefWidth="980"
                                                prefHeight="65"
                                                styleClass="new-compare-btn"
                                                onAction="#handleNewComparison"/>
                                    </children>
                                    <padding>
                                        <Insets top="20" right="20" bottom="30" left="20"/>
                                    </padding>
                                </VBox>

                            </children>
                        </StackPane>
                    </content>
                </ScrollPane>
            </center>

        </BorderPane>

        <VBox fx:id="profileMenu"
              visible="false"
              managed="false"
              prefWidth="300"
              maxWidth="300"
              prefHeight="170"
              maxHeight="170"
              spacing="12"
              styleClass="profile-menu"
              StackPane.alignment="TOP_RIGHT"
              translateX="-20"
              translateY="85">

            <children>
                <VBox spacing="2">
                    <children>
                        <Label fx:id="profileNameLabel"
                               styleClass="profile-name"/>

                        <Label fx:id="profileUsernameLabel"
                               styleClass="profile-username"/>
                    </children>
                </VBox>

                <Separator />

                <VBox fx:id="searchHistoryBox" spacing="8">
                    <children>
                        <Label text="No search history yet. Start searching to see your history here!"
                               wrapText="true"
                               styleClass="profile-history" />
                    </children>
                </VBox>

                <Separator />

                <Label text="Logout"
                       onMouseClicked="#handleLogout"
                       styleClass="logout-text"/>
            </children>

            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
        </VBox>

    </children>
</StackPane>
