<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Separator?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sportsintel.CompareController"
            styleClass="home-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="top-bar">
            <children>
                <ImageView fx:id="navLogo"
                           fitWidth="100"
                           fitHeight="100"
                           preserveRatio="true" />

                <Label text="SportsIntel Analytics" styleClass="top-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Home" styleClass="home-btn" onAction="#handleHomeClick"/>
                <Button text="Compare" styleClass="compare-btn" />
                <Button text="Help" styleClass="help-btn" onAction="#handleHelpClick" />

                <HBox fx:id="authButtons" spacing="10" alignment="CENTER_RIGHT">
                    <children>
                        <Button text="Login" styleClass="login-btn" onAction="#handleLoginClick" />
                        <Button text="Sign Up" styleClass="signup-btn" onAction="#handleSignUpClick" />
                    </children>
                </HBox>

                <VBox fx:id="profileBox" visible="false" managed="false">
                    <children>
                        <StackPane fx:id="profileButton"
                                   onMouseClicked="#toggleProfileMenu"
                                   styleClass="profile-circle">
                            <Label text="👤" styleClass="profile-icon-text"/>

                            <ImageView fx:id="profileImage"
                                       fitWidth="32"
                                       fitHeight="32"
                                       preserveRatio="true"/>
                        </StackPane>
                    </children>
                </VBox>
            </children>

            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>
        </HBox>
    </top>

    <center>
        <StackPane styleClass="center-area">
            <children>
                <VBox spacing="24"
                      maxWidth="900"
                      alignment="CENTER"
                      styleClass="search-card">

                    <children>
                        <ImageView fx:id="mainLogo"
                                   fitWidth="220"
                                   fitHeight="220"
                                   preserveRatio="true" />

                        <Label text="Compare Players"
                               styleClass="compare-title" />

                        <Label text="Modern NBA comparison against the same opponent"
                               styleClass="compare-subtitle" />

                        <Label text="Stats include regular season games from 2014–15 through the current season."
                               styleClass="compare-note" />

                        <HBox spacing="40" alignment="CENTER">
                            <children>

                                <VBox spacing="8" prefWidth="330">
                                    <children>
                                        <Label text="Player 1" styleClass="field-label" />
                                        <TextField fx:id="playerOneField"
                                                   promptText="e.g., LeBron James"
                                                   prefWidth="330" />
                                    </children>
                                </VBox>

                                <Label text="→" styleClass="compare-arrow" />

                                <VBox spacing="8" prefWidth="330">
                                    <children>
                                        <Label text="Player 2" styleClass="field-label" />
                                        <TextField fx:id="playerTwoField"
                                                   promptText="e.g., Kevin Durant"
                                                   prefWidth="330" />
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <VBox spacing="8" alignment="CENTER">
                            <children>
                                <Label text="Opponent" styleClass="field-label" />
                                <ComboBox fx:id="compareOpponentCombo"
                                          promptText="Select opponent"
                                          prefWidth="500" />
                            </children>
                        </VBox>

                        <Button text="Compare Players"
                                styleClass="search-btn"
                                prefWidth="740"
                                prefHeight="50"
                                onAction="#handleCompareSubmit"/>
                    </children>

                    <padding>
                        <Insets top="34" right="36" bottom="34" left="36"/>
                    </padding>
                </VBox>
                <VBox fx:id="profileMenu"
                      visible="false"
                      managed="false"
                      maxWidth="300"
                      prefWidth="300"
                      spacing="12"
                      styleClass="profile-menu"
                      StackPane.alignment="TOP_RIGHT"
                      translateX="-10"
                      translateY="20">

                    <children>
                        <VBox spacing="4">
                            <children>
                                <Label fx:id="profileNameLabel"
                                       text="Dan Gron"
                                       styleClass="profile-name" />
                                <Label fx:id="profileUsernameLabel"
                                       text="@ForeignStage"
                                       styleClass="profile-username" />
                            </children>
                        </VBox>

                        <Separator />

                        <Label text="No search history yet. Start searching to see your history here!"
                               wrapText="true"
                               styleClass="profile-history" />

                        <Separator />

                        <Button text="Logout"
                                styleClass="logout-btn"
                                onAction="#handleLogout" />
                    </children>

                    <padding>
                        <Insets top="14" right="14" bottom="14" left="14"/>
                    </padding>
                </VBox>
            </children>
        </StackPane>
    </center>

</BorderPane>
